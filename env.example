# Copy this file to .env and fill in your values, then: source .env
# Never commit .env to git — it's in .gitignore

# ── Required ────────────────────────────────────────────────────────────────

# Anthropic API key — used by the main model (AnthropicLLMClient)
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Brief OAuth token — used by the brief arm ONLY (adapters/brief.py)
# How to get it:
#   1. Run: claude mcp add --transport http brief https://app.briefhq.ai/mcp
#   2. Run /mcp inside Claude Code, pick "brief", authenticate in browser
#   3. The token is stored locally by Claude Code — copy it here
# If this is not set, the brief arm is automatically skipped with a notice.
BRIEF_OAUTH_TOKEN="..."

# ── Optional (not yet implemented) ──────────────────────────────────────────

# OpenAI API key — for the GPT robustness row
# Not yet implemented (configs/models.json: implemented: false)
# Set this when the OpenAI LLMClient backend is added
# OPENAI_API_KEY="sk-..."

# Together AI key — for the open-weight robustness row (Llama 4 Maverick)
# Not yet implemented (configs/models.json: implemented: false)
# TOGETHER_API_KEY="..."
